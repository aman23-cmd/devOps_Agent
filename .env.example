# ═══════════════════════════════════════════════════════════════
#  DevOps Pipeline Agent — Environment Variables
#  Copy this file to .env and fill in real values
# ═══════════════════════════════════════════════════════════════

# ── AI / LLM ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── GitHub ────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your-personal-access-token
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# ── Slack ─────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_CHANNEL_ID=#devops-alerts

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://devops:devops@postgres:5432/devops_agent

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Cloud Providers (optional — leave blank to skip) ─────────
GCP_PROJECT_ID=
AWS_REGION=
AWS_LOG_GROUP=

# ── PagerDuty (optional — for escalation alerts) ─────────────
PAGERDUTY_ROUTING_KEY=

# ── Application ──────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
MAX_LOG_LINES=5000
AUTOGEN_MAX_ROUNDS=15
